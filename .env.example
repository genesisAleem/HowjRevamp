# Copy this file to .env for local dev (Vite auto-loads .env, it's gitignored).
# These are used by the build-time Notion fetch script (scripts/fetch-notion-content.mjs),
# which runs on your machine / CI — never in the browser.

# Notion internal integration token (Settings > Connections > Develop or manage integrations)
NOTION_TOKEN=secret_xxx

# The Notion page or database ID that holds site content (share it with the integration first)
NOTION_CONTENT_SOURCE_ID=

# --- Registration function (deployed separately, e.g. Cloudflare Workers — see functions/README.md) ---
# The Notion database ID where signups (name/email/phone) get written
NOTION_REGISTRATIONS_DB_ID=

# Public URL of the deployed registration function, consumed by the frontend.
# Must be prefixed with VITE_ so Vite exposes it to client code.
VITE_REGISTER_ENDPOINT=https://your-worker-subdomain.workers.dev/register
